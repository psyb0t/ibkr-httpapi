events {}

http {
    server {
        listen 80;
        client_max_body_size 25m;
        client_body_timeout 120s;

        location / {
            proxy_pass http://api:8889;
            proxy_set_header Host $host;
            proxy_set_header X-Forwarded-For $remote_addr;
            proxy_read_timeout 300s;
        }
    }
}
